package roles

import "github.com/yaien/cultural/internal/web/dashboard/views/dashboard"

templ Create() {
	@dashboard.Modal("Invitar Usuario") {
		<form
			hx-post={ templ.URL("/dashboard/roles") }
			hx-target="dialog"
			hx-swap="outerHTML swap:250ms"
			hx-disable-elt="find button"
		>
			<fieldset>
				<legend>Nombre</legend>
				<input name="name" required/>
			</fieldset>
			<fieldset>
				<legend>Correo</legend>
				<input name="email" type="email" required/>
			</fieldset>
			<div class="actions">
				<button>Invitar</button>
			</div>
		</form>
	}
}
