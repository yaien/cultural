package dashboard

import (
	"github.com/yaien/cultural/internal/library/admin"
	"github.com/yaien/cultural/internal/modules/configs/internal/interface/web/middlewares"
	"github.com/yaien/cultural/internal/modules/configs/internal/interface/web/views/icons"
)

templ Page(title string) {
	{{ role := ctx.Value(middlewares.RoleContextKey).(*admin.Role) }}
	{{ path := ctx.Value(middlewares.PathContextKey).(string) }}
	<!DOCTYPE html>
	<html lang="es">
		<head>
			@Head(title)
		</head>
		<body x-data="{ open: false }" :class="{ open }">
			<header>
				<div class="start">
					<button id="toggle" class="toggle" @click="open = !open">
						<div x-show="!open">
							@icons.Menu()
						</div>
						<div x-show="open">
							@icons.Close()
						</div>
					</button>
					<div class="title">
						<h3>{ title }</h3>
					</div>
				</div>
				<div class="end">
					<div class="account">
						<span>{ role.UserName } ({ role.UserEmail })</span>
					</div>
				</div>
			</header>
			<aside>
				<nav>
					<ul>
						@Link(path, "/dashboard", "Dashboard", icons.Home())
						@Link(path, "/dashboard/pages", "Sitios", icons.Website())
						@Link(path, "/dashboard/events", "Eventos", icons.Calendar())
						@Link(path, "/dashboard/products", "Productos", icons.Box())
						@Link(path, "/dashboard/roles", "Roles", icons.UserList())
						@Link(path, "/dashboard/integrations", "Integraciones", icons.Apps())
					</ul>
				</nav>
				<div class="footer">
					<nav>
						<ul>
							<li>
								<form action="/auth/logout" method="POST" x-ref="logout">
									<a href="" @click.prevent="$refs.logout.submit()">
										@icons.Logout()
										<span>Cerrar Sesión </span>
									</a>
								</form>
							</li>
						</ul>
					</nav>
				</div>
			</aside>
			<main>
				{ children... }
			</main>
		</body>
	</html>
}
